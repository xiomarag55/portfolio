{
  "name": "portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "set-env": "node scripts/set-env.mjs",
    "set-env:dev": "node --env-file=.env scripts/set-env.mjs --dev",
    "start": "npm run set-env:dev && ng serve",
    "build": "ng build",
    "build:vercel": "npm run set-env && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@emailjs/browser": "^4.4.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.8.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.0",
    "typescript": "~5.9.2"
  }
}
